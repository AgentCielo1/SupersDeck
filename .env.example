# Copy this to .env.local and fill in once you wire up Supabase (phase 2).
# For phase 1 the app runs entirely on bundled seed data — no env needed.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 7: Resend HTTP API for the Class-C violation digest email.
# Get the key at https://resend.com/api-keys. Until you verify a custom
# domain, RESEND_FROM_EMAIL must be onboarding@resend.dev and the email
# only sends to your Resend account's owner address.
RESEND_API_KEY=
RESEND_FROM_EMAIL="SupersDeck <onboarding@resend.dev>"

# Phase 7: protects /api/violations/refresh and /api/cron/violations-alert
# from random hits. Generate with: openssl rand -hex 16
# Vercel Cron sends this automatically; set the same value in Vercel's
# Environment Variables panel.
CRON_SECRET=

# Phase 10: Web Push (PWA notifications when a tenant submits a WO).
# Generate a fresh pair with:  npx web-push generate-vapid-keys
# NEXT_PUBLIC_ prefix on the public one is required — it ships to the
# browser so PushManager.subscribe() can use it.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL="mailto:you@yourdomain.com"

# Base URL for tracking links in emails (so "/track/<ticket>" is absolute).
# Set to your production origin. Falls back to the per-deployment Vercel URL.
NEXT_PUBLIC_BASE_URL="https://supersdeck.vercel.app"

# Phase 10b: Anthropic API key used to auto-translate tenant WO submissions
# into English (Claude Haiku). Get one at https://console.anthropic.com/.
# If unset, WOs ship in whatever language the tenant typed — no failure.
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Emergency Notifications — Twilio SMS (EMERGENCY tier only).
# -----------------------------------------------------------------------------
# SMS is the hard fallback for life-safety alerts. If unset, SMS is skipped
# (push + email still fire). Get these from the Twilio console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Direct line for the building owner, paged when an EMERGENCY alert goes
# unacknowledged past the escalation window (10 min). Optional.
OWNER_ALERT_PHONE=
OWNER_ALERT_EMAIL=

# -----------------------------------------------------------------------------
# Stripe Billing ($49/building/month).
# -----------------------------------------------------------------------------
# Create a Product "SupersDeck Property Plan" with a $49/mo recurring Price,
# then paste the Price ID below. STRIPE_WEBHOOK_SECRET comes from the webhook
# endpoint you register at https://dashboard.stripe.com/webhooks pointing to
# /api/billing/webhook.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_BUILDING_MONTHLY=
