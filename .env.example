# Copy this to .env.local and fill in once you wire up Supabase (phase 2).
# For phase 1 the app runs entirely on bundled seed data — no env needed.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Phase 7: Resend HTTP API for the Class-C violation digest email.
# Get the key at https://resend.com/api-keys. Until you verify a custom
# domain, RESEND_FROM_EMAIL must be onboarding@resend.dev and the email
# only sends to your Resend account's owner address.
RESEND_API_KEY=
RESEND_FROM_EMAIL="SupersDeck <onboarding@resend.dev>"

# Phase 7: protects /api/violations/refresh and /api/cron/violations-alert
# from random hits. Generate with: openssl rand -hex 16
# Vercel Cron sends this automatically; set the same value in Vercel's
# Environment Variables panel.
CRON_SECRET=
